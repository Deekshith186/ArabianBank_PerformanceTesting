def file = new File(&quot;D:\Jmeter_Results/account_balance_data.csv&quot;)

 if (!file.exists()) 
 
       {
        file.append(&quot;AccountNo,Balance\n&quot;)
        }
 
 file.append(&quot;${accountNo},${balance}\n&quot;)*/

</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223PostProcessor>

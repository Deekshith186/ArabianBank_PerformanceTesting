            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor" enabled="true">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">// Fetch values from JMeter variables
def accountNo = vars.get(&quot;c_User&quot;)
def balance   = vars.get(&quot;c_Balance&quot;)

// Define the file path
def file = new File(&quot;D:/Offline/Arabian_Bank/Jmeter/Results/account_balance.csv&quot;)

// If file does not exist, create it and write header
if (!file.exists()) {
    file.parentFile.mkdirs()   // ensures directory exists
    file.append(&quot;AccountNo,Balance\n&quot;)
}

// Append account data
file.append(&quot;${accountNo},${balance}\n&quot;)
e()


/*def accountNo = vars.get(&quot;c_User&quot;)

              <BoundaryExtractor guiclass="BoundaryExtractorGui" testclass="BoundaryExtractor" testname="Boundary Extractor" enabled="false">
                <stringProp name="BoundaryExtractor.useHeaders">false</stringProp>
                <stringProp name="BoundaryExtractor.refname">c_balance</stringProp>
                <stringProp name="BoundaryExtractor.lboundary">class=&quot;PersonalData&quot;&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;</stringProp>
                <stringProp name="BoundaryExtractor.rboundary">/-</stringProp>
                <stringProp name="BoundaryExtractor.default">c_balance_NOT_FOUND</stringProp>
                <boolProp name="BoundaryExtractor.default_empty_value">false</boolProp>
                <stringProp name="BoundaryExtractor.match_number">1</stringProp>
                <stringProp name="TestPlan.comments">&lt;strong&gt;Balance 
		&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp; &lt;/strong&gt;&lt;/div&gt;&lt;/td&gt;
              &lt;td valign=&quot;top&quot; class=&quot;PersonalData&quot;&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;77446/-&lt;/td&gt;</stringProp>
              </BoundaryExtractor>
              <hashTree/>
              <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor" enabled="false">
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="script">def Accbalance  = vars.get(&quot;c_balance&quot;) 
def CleanBalance=Accbalance.replaceAll(&quot;[^0-9]&quot;,&quot;&quot;)
def amount=CleanBalance.toInteger()
def AccNumber=vars.get(&quot;p_accno&quot;)

def file = new File(&quot;E:/Arabian__Banking/Jmeter_Projects/Jmter_write_files/FoundTransfer.csv&quot;)

if (!file.exists()) {
    file.write(&quot;AccNumber,Accbalance\n&quot;, &quot;UTF-8&quot;)
}


file.append(&quot;\&quot;${AccNumber}\&quot;,\&quot;${Accbalance}\&quot;\n&quot;,&quot;UTF-8&quot;);


vars.put(&quot;balanceCheck&quot;, (amount &gt;= 1000).toString())

log.info(&quot;Clean Balance = &quot; + amount)</stringProp>
                <stringProp name="scriptLanguage">groovy</stringProp>
              </JSR223PostProcessor>
              <hashTree/>
            </hashTree>
          </hashTree>

                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="script">def Accbalance  = vars.get(&quot;c_balance&quot;) 
def CleanBalance=Accbalance.replaceAll(&quot;[^0-9]&quot;,&quot;&quot;)
def amount=CleanBalance.toInteger()
def AccNumber=vars.get(&quot;p_accno&quot;)

def file = new File(&quot;E:/Arabian__Banking/Jmeter_Projects/Jmter_write_files/FoundTransfer.csv&quot;)

if (!file.exists()) {
    file.write(&quot;AccNumber,Accbalance\n&quot;, &quot;UTF-8&quot;)
}


file.append(&quot;\&quot;${AccNumber}\&quot;,\&quot;${Accbalance}\&quot;\n&quot;,&quot;UTF-8&quot;);


vars.put(&quot;balanceCheck&quot;, (amount &gt;= 1000).toString())

log.info(&quot;Clean Balance = &quot; + amount)</stringProp>
                <stringProp name="scriptLanguage">groovy</stringProp>
              </JSR223PostProcessor>

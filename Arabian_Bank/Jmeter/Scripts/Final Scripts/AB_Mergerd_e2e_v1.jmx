                <stringProp name="parameters"></stringProp>
                <stringProp name="script">def filePath = &quot;D:/Offline/Arabian_Bank/Jmeter/Results/Amount_commision.csv&quot;

def p_amount = vars.get(&quot;p_amount&quot;)
def c_commision = vars.get(&quot;c_commision&quot;)

def file = new File(filePath)

if (!file.exists() || file.length() == 0) {
    file.text = &quot;p_amount,c_commision\n&quot;
}

file.append(&quot;${p_amount},${c_commision}\n&quot;)

log.info(&quot;Written to file -&gt; p_amount: ${p_amount}, c_commision: ${c_commision}&quot;)</stringProp>
                <stringProp name="scriptLanguage">groovy</stringProp>
              </JSR223PostProcessor>

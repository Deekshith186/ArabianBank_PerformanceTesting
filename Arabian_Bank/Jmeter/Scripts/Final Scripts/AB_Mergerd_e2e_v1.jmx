              <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor" enabled="false">
                <stringProp name="cacheKey">true</stringProp>
                <stringProp name="filename"></stringProp>
                <stringProp name="parameters"></stringProp>
                <stringProp name="script">def balance = vars.get(&quot;c_balance&quot;)
        .replaceAll(&quot;[^0-9.]&quot;, &quot;&quot;)
        .toBigDecimal()

def payAmount = vars.get(&quot;p_amount_pay&quot;).toBigDecimal()

if (balance &lt; payAmount) {
    vars.put(&quot;ALLOW_TRANSFER&quot;, &quot;NO&quot;)
    vars.put(&quot;ERROR_MSG&quot;,
            &quot;Insufficient balance. Available: ${balance}, Requested: ${payAmount}&quot;)
} else {
    vars.put(&quot;ALLOW_TRANSFER&quot;, &quot;YES&quot;)
}</stringProp>
                <stringProp name="scriptLanguage">groovy</stringProp>
              </JSR223PreProcessor>

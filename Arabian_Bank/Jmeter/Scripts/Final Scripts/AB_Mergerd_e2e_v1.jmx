 if (!file.exists()) 
 
       {
        file.append(&quot;AccountNo,Balance\n&quot;)
        }
 
 file.append(&quot;${accountNo},${balance}\n&quot;)*/

</stringProp>
                <stringProp name="scriptLanguage">groovy</stringProp>
